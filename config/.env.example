# .env.example
# Allgemeine Umgebungsvariablen fuer Zeus RPG PromptKit
# 
# Verwendung:
#   1. In .env.local kopieren und alle Werte anpassen
#   2. Niemals .env.local ins Repo commiten!
#   3. PowerShell: . .\config\load-env.ps1
#
# WICHTIG: Diese Datei dient nur als Vorlage. 
# Erstelle .env.local mit deinen echten Werten!
#
# ── Multi-Maschinen-Setup (z.B. SYS_TEST Sourcen + SYS_PROD Daten) ──────────────
# Env-Vars haben immer Vorrang vor Profilwerten (12-Factor).
# Fuer ein Setup mit zwei Maschinen reicht es, in .env.project.local zu setzen:
#
#   ZEUS_FETCH_HOST=SYS_TEST               <- Sourcen von Testsystem holen
#   ZEUS_DB_HOST=SYS_TEST                  <- DB-Default (z.B. fuer query-sql)
#   ZEUS_DB_USER=IBMI_USER
#   ZEUS_DB_PASSWORD=***
#   ZEUS_METADATA_DB_HOST=SYS_PROD         <- Analyse/Metadaten gegen Prod
#   ZEUS_METADATA_DB_USER=IBMI_USER
#   ZEUS_METADATA_DB_PASSWORD=***
#
# Oder alles gegen SYS_TEST (einfachstes Setup):
#   Einfach ZEUS_METADATA_DB_HOST weglassen -> faellt auf ZEUS_DB_HOST zurueck.
# ──────────────────────────────────────────────────────────────────────────────

# ── Output und Source Root
ZEUS_OUTPUT_ROOT=./output
ZEUS_SOURCE_ROOT=./rpg_sources

# ── Standard DB-Verbindung (Default fuer alle DB-Operationen)
ZEUS_DB_HOST=HOSTNAME_ODER_IP
ZEUS_DB_URL=
ZEUS_DB_USER=IBMI_USER
ZEUS_DB_PASSWORD=IBMI_PASSWORD
ZEUS_DB_DEFAULT_LIBRARY=APPDATA
ZEUS_DB_DEFAULT_SCHEMA=APPDATA

# ── Standard Fetch-Verbindung (Source-Export von IBM i)
ZEUS_FETCH_HOST=HOSTNAME_ODER_IP
ZEUS_FETCH_PORT=22
ZEUS_FETCH_USER=IBMI_USER
ZEUS_FETCH_PASSWORD=IBMI_PASSWORD
ZEUS_FETCH_SOURCE_LIB=QRPGLESRC
ZEUS_FETCH_SOURCE_LIBRARY=QRPGLESRC
ZEUS_FETCH_IFS_DIR=/tmp/zeus-fetch
ZEUS_FETCH_OUT=./analysis/zeus-fetch
ZEUS_FETCH_SOURCE_FILES=QRPGLESRC,QCLSRC,QDDSSRC
ZEUS_FETCH_MEMBERS=
ZEUS_FETCH_REPLACE=true
ZEUS_FETCH_STREAMFILE_CCSID=1208
ZEUS_FETCH_TRANSPORT=auto
ZEUS_FETCH_NETWORK_TYPE=internet
ZEUS_FETCH_PREFER_TRANSPORT=sftp
ZEUS_FETCH_DIAGNOSE_TRANSPORT=true
ZEUS_FETCH_ENCRYPTED=true
ZEUS_FETCH_TRANSPORT_TIMEOUT_MS=60000

# ── Metadata-Rolle (optional — fuer Multi-Maschinen: andere Maschine als ZEUS_DB_HOST)
# Wenn nicht gesetzt: faellt auf ZEUS_DB_* zurueck.
ZEUS_METADATA_DB_HOST=HOSTNAME_ODER_IP
ZEUS_METADATA_DB_URL=
ZEUS_METADATA_DB_USER=IBMI_USER
ZEUS_METADATA_DB_PASSWORD=IBMI_PASSWORD
ZEUS_METADATA_DB_DEFAULT_LIBRARY=APPDATA
ZEUS_METADATA_DB_DEFAULT_SCHEMA=APPDATA

# ── TestData-Rolle (optional — fuer Testdaten-Export)
# Wenn nicht gesetzt: faellt auf ZEUS_METADATA_DB_* zurueck.
ZEUS_TESTDATA_DB_HOST=HOSTNAME_ODER_IP
ZEUS_TESTDATA_DB_URL=
ZEUS_TESTDATA_DB_USER=IBMI_USER
ZEUS_TESTDATA_DB_PASSWORD=IBMI_PASSWORD
ZEUS_TESTDATA_DB_DEFAULT_LIBRARY=APPDATA
ZEUS_TESTDATA_DB_DEFAULT_SCHEMA=APPDATA
