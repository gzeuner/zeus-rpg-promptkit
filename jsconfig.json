{
  "compilerOptions": {
    "target": "ES2022",
    "module": "node16",
    "moduleResolution": "node16",
    "checkJs": true,
    "noEmit": true,
    "strict": false,
    "skipLibCheck": false,
    "allowJs": true,
    "types": ["node"],
    "resolveJsonModule": true
  },
  "files": [
    "src/core/capabilityRegistry.js",
    "src/mcp/mcpPolicy.js",
    "src/api/zeusApi.js",
    "src/providers/contracts.js",
    "src/providers/egressPolicy.js",
    "src/providers/redaction.js",
    "src/providers/providerRegistry.js",
    "src/providers/testing.js",
    "types.d.ts"
  ],
  "exclude": ["node_modules", "output", "**/output*/**", "java", "bundles"]
  // Intentionally scoped "core type checking" (JSDoc) to the listed maintained entry points above.
  // This is NOT a project-wide claim. Expanding scope requires updating this list + the prevention test.
  // Uses --noResolve to keep check strictly limited to declared files without pulling in unrelated module errors.
  // See package.json#typecheck (direct tsc preserves exit code; no output filtering).
}
