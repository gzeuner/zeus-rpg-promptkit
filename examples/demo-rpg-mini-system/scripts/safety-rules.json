{
  "scanRoot": "examples/demo-rpg-mini-system",
  "includeExtensions": [
    ".md",
    ".rpgle",
    ".sqlrpgle",
    ".clle",
    ".pf",
    ".lf",
    ".dds",
    ".sql",
    ".json",
    ".mmd",
    ".sh",
    ".ps1",
    ".mjs"
  ],
  "denyPatterns": [
    {
      "name": "email-address",
      "regex": "[A-Za-z0-9._%+-]+@[A-Za-z0-9.-]+\\.[A-Za-z]{2,}"
    },
    {
      "name": "credential-keyword",
      "regex": "(?i)(password\\s*=|pwd\\s*=|apikey\\s*=|api_key\\s*=|token\\s*=)"
    },
    {
      "name": "ipv4-address",
      "regex": "\\b(?:\\d{1,3}\\.){3}\\d{1,3}\\b"
    }
  ],
  "allowPatterns": [
    {
      "name": "placeholder-identifiers",
      "regex": "\\b(?:PROGRAM|FILE|TABLE|SCHEMA|VALUE)_[0-9]{3}\\b"
    }
  ]
}
