.DS_Store
Thumbs.db

# -----------------------------
# Generated analysis output
# -----------------------------

output/*
!output/.gitkeep
analysis/zeus-fetch/
bundles/
*.zip
*.7z

# Common analysis artifact names produced by this toolkit (prevent leaking real analyses)
**/*-analysis.json
**/*-context.json
**/*-optimized-context.json
**/*-ai-knowledge.json
**/*-analyze-run-manifest.json
**/*-workflow-run-manifest.json
**/*-risk-assessment.json
**/*-impact-analysis.json
**/*-bundle-manifest.json
**/*-analysis-index.json
**/*-program-call-tree.json
**/ai-*.md
**/architecture-report.md
**/dependency-graph.*
**/canonical-analysis.json

# Additional local analysis / work directories
**/*-work/
**/*-scratch/
**/*-tmp-analysis/
**/*-output/

# Note: Do NOT broadly ignore *-baseline/ because examples/demo-rpg-mini-system/output-baseline/
# and some test fixtures intentionally contain baseline artifacts for reproducibility.
# If you have personal analysis baselines, they should go under output/ or .local/ which are already ignored.

