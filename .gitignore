# -----------------------------
# Secrets and local config
# ────────────────────────────
# Keep committed: .env.example, profiles.example.json (templates)
# Ignore local:   .env.local, local-only profiles (user credentials)
# ────────────────────────────

.env
.env.*
!.env.example
config/.env
config/.env.*
!config/.env.example
.env.local
.env.*.local
*Kopie.local
*.secret
*.secrets
*.credentials
credentials.*
config/local.*
config/private.*
# Local profile credentials — never commit them.
# Copy config/profiles.example.json to config/local-only/profiles.json and fill in your values.
config/local-only/
config/profiles.json

# Additional credential and key files
*.pem
*.key
id_rsa*
id_dsa*
id_ecdsa*
id_ed25519*
*.crt
*.p12
*.pfx
**/*-private-key*
**/*-key.pem
**/*-cert.pem

# Local scratch / temp credential stores
**/*-creds*
**/*-secrets*
**/*-passwords*

